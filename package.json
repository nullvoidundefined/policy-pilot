{
  "name": "policy-pilot",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --filter policy-pilot-common build && pnpm --filter policy-pilot-server build && pnpm --filter policy-pilot-worker build && pnpm --filter policy-pilot-web build",
    "lint": "eslint --config eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config prettier.config.bottomlessmargaritas.mjs --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --config prettier.config.bottomlessmargaritas.mjs --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test": "pnpm --filter policy-pilot-common run test && pnpm --filter policy-pilot-server run test",
    "smoke": "bash scripts/smoke-test.sh",
    "test:integration": "pnpm --filter policy-pilot-server run test:integration",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && lefthook install || true"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@playwright/test": "^1.52.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.4.0",
    "lefthook": "^2.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@bottomlessmargaritas/claude-architecture-prompts": "3.0.0"
  }
}
